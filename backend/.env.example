# CV Pilot v2 Backend Configuration
# Copy this file to .env and fill in your own values

# ════════════════════════════════════════════════════════════════
# SUPABASE (Required)
# ════════════════════════════════════════════════════════════════
# Get these from: https://supabase.com → Your Project → Settings → API

# Your Supabase project URL
# Example: https://abcdef123456.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase service role key (NOT the anon key!)
# Go to Settings → API → Project API Keys
# Copy the "service_role" key (the secret one, not the publishable one)
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Your Supabase JWT secret (for token verification)
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ════════════════════════════════════════════════════════════════
# ANTHROPIC API (Required)
# ════════════════════════════════════════════════════════════════
# Get this from: https://console.anthropic.com → API Keys

# Your Anthropic API key (starts with sk-ant-)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ════════════════════════════════════════════════════════════════
# FASTAPI CONFIGURATION
# ════════════════════════════════════════════════════════════════

# Environment (development or production)
ENV=development

# Secret key for signing JWTs
# IMPORTANT: Change this to a random string in production!
SECRET_KEY=change-me-to-a-long-random-string-in-production

# Backend URL
BACKEND_URL=http://localhost:8000

# Frontend URL (must match your frontend domain for CORS)
# Local: http://localhost:5173
# Production: https://your-vercel-domain.com
FRONTEND_URL=http://localhost:5173

# ════════════════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ════════════════════════════════════════════════════════════════

# Server port
PORT=8000

# Server host
HOST=0.0.0.0

# ════════════════════════════════════════════════════════════════
# OPTIONAL: GOOGLE OAUTH
# ════════════════════════════════════════════════════════════════
# Leave blank if not using Google OAuth
# See docs/GOOGLE_OAUTH_SETUP.md for instructions

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# ════════════════════════════════════════════════════════════════
# OPTIONAL: DATABASE (not needed if using Supabase)
# ════════════════════════════════════════════════════════════════

DATABASE_URL=
